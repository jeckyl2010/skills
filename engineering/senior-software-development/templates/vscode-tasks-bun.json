{
  "version": "2.0.0",
  "options": {
    "env": {
      "PATH": "${env:HOME}/.bun/bin:${env:PATH}"
    }
  },
  "tasks": [
    {
      "label": "dev",
      "type": "shell",
      "command": "bun run dev",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "owner": "next",
        "pattern": { "regexp": "^(.*)$", "file": 1, "line": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting\\.\\.\\.",
          "endsPattern": "Ready in"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "build",
      "type": "shell",
      "command": "bun run build",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "start",
      "type": "shell",
      "command": "bun run start",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "test",
      "type": "shell",
      "command": "bun test tests/",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "test:watch",
      "type": "shell",
      "command": "bun test --watch tests/",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": "test",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "bun run typecheck",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "bun run lint",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
